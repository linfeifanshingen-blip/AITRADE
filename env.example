# Copy to .env.local for local dev. Do NOT commit .env.local.
# (File named env.example w/o dot — macOS sandboxes sometimes block dotfile writes;
#  rename or symlink as needed for your setup.)

# --- LLM providers (DeepSeek for deep_think, Kimi for quick_think) ---
DEEPSEEK_API_KEY=
DEEPSEEK_QUICK_MODEL=deepseek-v4-pro
DEEPSEEK_DEEP_MODEL=deepseek-v4-pro
KIMI_API_KEY=
MOONSHOT_API_KEY=
KIMI_QUICK_MODEL=kimi-k2.6
KIMI_DEEP_MODEL=kimi-k2.6
OPENAI_API_KEY=
OPENAI_QUICK_MODEL=gpt-5.5
OPENAI_DEEP_MODEL=gpt-5.5
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_QUICK_MODEL=qwen3.6-plus
QWEN_DEEP_MODEL=qwen3.7-max
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_QUICK_MODEL=glm-5.1
ZHIPU_DEEP_MODEL=glm-5.1
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_QUICK_MODEL=MiniMax-M2.7
MINIMAX_DEEP_MODEL=MiniMax-M2.7
# Optional default shown/used before the user changes the selector: mix, deepseek, minimax, kimi, or openai.
DEFAULT_MODEL_PROVIDER=deepseek
# Model-call stability/speed knobs.
OPENAI_LLM_CONCURRENCY=2
OPENAI_LLM_MAX_RETRIES=5
OPENAI_LLM_TIMEOUT_MS=240000
DEEPSEEK_LLM_CONCURRENCY=5
REPORT_CONTEXT_CHARS=5600

# --- News (Tavily, can reuse from ai-research-daily) ---
TAVILY_API_KEY=
MARKETAUX_API_TOKEN=
ALPHAVANTAGE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
NEWSAPI_API_KEY=
BENZINGA_API_KEY=
FMP_API_KEY=
EODHD_API_TOKEN=
SEC_USER_AGENT=silicon-trader contact@example.com

# --- Social sentiment official APIs (optional but recommended) ---
# xAI Grok X Search: optional. When configured, Grok searches X posts and feeds
# the synthesis into both Intelligence Analyst and Macro Analyst.
XAI_API_KEY=
XAI_X_SEARCH_MODEL=grok-4.3

# X recent search uses GET /2/tweets/search/recent and covers the last 7 days.
X_BEARER_TOKEN=
# Reddit OAuth app-only access for /search and /r/{subreddit}/search listings.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=silicon-trader/0.1 contact@example.com

# --- Market data (optional Futu OpenD local gateway) ---
# Start Futu OpenD locally, then enable this if you want Futu as the first price source.
# PRICE_PROVIDER=auto uses Futu only when FUTU_ENABLED=true, then falls back to public sources.
# PRICE_PROVIDER=futu-only fails fast if Futu is unavailable.
PRICE_PROVIDER=auto
FUTU_ENABLED=false
FUTU_WS_HOST=127.0.0.1
FUTU_WS_PORT=8080
FUTU_WS_SSL=false
FUTU_WS_KEY=
FUTU_MARKET=
FUTU_REHAB_TYPE=none
FUTU_TIMEOUT_MS=5000

# --- Persistence (Upstash Redis via Vercel Marketplace) ---
# Vercel Marketplace auto-injects these when you attach Upstash:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Some templates use the older Vercel KV names; we accept both:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Site auth (optional; cron + UI password) ---
CRON_SECRET=
SITE_PASSWORD=

# --- Optional: upgrade to Sonnet for deep_think if you want better reasoning ---
# ANTHROPIC_API_KEY=
